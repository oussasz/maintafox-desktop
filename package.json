{
  "name": "maintafox-desktop",
  "version": "0.1.0-dev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "lint": "eslint src shared --fix",
    "lint:check": "eslint src shared",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "format": "prettier --write src shared",
    "format:check": "prettier --check src shared",
    "format:rust": "cd src-tauri && cargo fmt",
    "format:rust:check": "cd src-tauri && cargo fmt --check",
    "lint:biome": "biome check src shared",
    "format:biome": "biome format --write src shared",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test",
    "clean": "rimraf dist src-tauri/target node_modules/.cache",
    "db:seed": "pnpm tsx scripts/dev-db-seed.ts",
    "db:reset": "pnpm tsx scripts/dev-db-reset.ts",
    "db:reset:ci": "pnpm tsx scripts/dev-db-reset.ts --yes",
    "migrate:check": "tsx scripts/check-migrations.ts",
    "audit:tauri-conf": "pnpm tsx scripts/audit-tauri-conf.ts",
    "guard:phase4:fixtures": "pnpm tsx scripts/check-control-plane-fixture-imports.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-table": "^8.20.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@types/d3": "^7.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "html-to-image": "^1.11.13",
    "i18next": "^24.0.0",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  }
}
